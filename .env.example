# Copy to .env for dev, or set these in your host (Render) for prod.

# PostgreSQL connection string.
#   dev:  postgresql://postgres:postgres@localhost:5432/accessmap
#   prod: use the Supabase "Session pooler" connection string
#         (Supabase → Project Settings → Database → Connection string).
DATABASE_URL=

# Port the API listens on. Render sets this automatically; leave blank in prod.
PORT=3000

# Supabase JWT secret — from Supabase → Settings → API → JWT Settings.
# Used by requireAuth middleware to verify incoming access tokens.
SUPABASE_JWT_SECRET=

# Python ML service (accessmap-ml) that runs Grounding DINO detection.
#   dev:  http://localhost:5001
#   prod (Hugging Face Space):
#     https://<hf-username>-<space-name>.hf.space
#   prod (Render web service):
#     https://accessmap-ml.onrender.com
ML_SERVICE_URL=http://localhost:5001

# Cloudinary image storage. Create a free account at https://cloudinary.com and
# copy these from the dashboard. If left blank, file uploads are disabled and
# the photos route only accepts an imageUrl.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated allowlist of frontend origins the browser will call from.
#   dev:  http://localhost:5173
#   prod: https://accessmap-frontend.onrender.com
# Add every host you want to allow (dev + prod + any preview URLs).
CORS_ORIGINS=http://localhost:5173
