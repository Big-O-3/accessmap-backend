# Copy to .env and fill in.

# PostgreSQL connection string (local or Render).
# Local example: postgresql://postgres:postgres@localhost:5432/accessmap
DATABASE_URL=

# Port the API listens on (defaults to 3000).
PORT=3000

# Python ML service (accessmap-ml) that runs YOLO-World detection.
ML_SERVICE_URL=http://localhost:5001

# Cloudinary image storage. Create a free account at https://cloudinary.com and
# copy these from the dashboard. If left blank, file uploads are disabled and
# the photos route only accepts an imageUrl.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
