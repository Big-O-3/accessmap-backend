# Copy to .env and fill in.

# PostgreSQL connection string (local or Render).
# Local example: postgresql://postgres:postgres@localhost:5432/accessmap
DATABASE_URL=

# Port the API listens on (defaults to 3000).
PORT=3000

# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=

# Python ML service (accessmap-ml) that runs Grounding DINO detection.
ML_SERVICE_URL=http://localhost:5001

# Cloudinary image storage. Create a free account at https://cloudinary.com and
# copy these from the dashboard. If left blank, file uploads are disabled and
# the photos route only accepts an imageUrl.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated allowlist of frontend origins that may send credentialed
# requests. Browsers reject "*" when credentials:include is set. Add each
# origin you dev from (localhost and any LAN URL for phone testing).
CORS_ORIGINS=https://localhost:5173

# Optional: serve HTTPS locally. Point these at PEM files. Required when the
# frontend runs over https://, because Secure session cookies won't be sent
# from a browser to an http:// backend. Leave unset for HTTP.
SSL_CERT=
SSL_KEY=
